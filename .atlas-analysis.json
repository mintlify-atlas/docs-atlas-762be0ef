  "keyFeatures": [
    "Passwordless email OTP authentication with JWT token issuance",
    "Trusted Execution Environment (TEE) for private key isolation",
    "Action-based REST API for semantic transaction execution",
    "Configurable policy engine with spending limits, daily caps, and recipient whitelists",
    "Native DeFi integrations: Jupiter (trading), Meteora (liquidity), Kalshi (predictions)",
    "Idempotency support to prevent duplicate financial transactions",
    "Machine-readable skill discovery endpoint for AI agent auto-discovery",
    "Immutable audit logging with USD-normalized transaction amounts"
  ],
  "publicApiSurface": [
    "POST /connect/start — initiate email OTP authentication",
    "POST /connect/complete — complete OTP and receive JWT + wallet address",
    "POST /connect/validate — validate an existing JWT token",
    "POST /connect/refresh — refresh an expiring JWT token",
    "GET /wallets/me/balances — retrieve SOL and SPL token balances",
    "GET /wallets/me/history — retrieve transaction history",
    "POST /wallets/me/actions/transfer-solana — transfer SOL",
    "POST /wallets/me/actions/trade — swap tokens via Jupiter",
    "GET /wallets/me/policy — view current agent policy",
    "PATCH /wallets/me/policy — update agent policy",
    "GET /health — service health check",
    "GET /tokens — list supported tokens",
    "GET /skill.md — machine-readable skill discovery for AI agents"
  ]
}
