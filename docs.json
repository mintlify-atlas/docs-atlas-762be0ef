{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Knot Wallet",
  "theme": "sequoia",
  "colors": {
    "primary": "#cb0404",
    "light": "#f3d2d2",
    "dark": "#e37b84"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/codewithmide/read"
    }
  },
